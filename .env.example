# Supabase PostgreSQL Connection (via Connection Pooling)
DATABASE_URL="postgresql://postgres.[PROJECT-ID]:YOUR-PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations (without connection pooling)
DIRECT_URL="postgresql://postgres.[PROJECT-ID]:YOUR-PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# NextAuth Configuration
NEXTAUTH_SECRET=your-generated-secret-key
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
